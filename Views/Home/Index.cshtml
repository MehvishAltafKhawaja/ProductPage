@{
    ViewData["Title"] = "Home Page";
}

<html>
<head>
   <style>
            .card {
                border-radius: 15px;
                transition: all 0.3s ease;
            }

                .card:hover {
                    transform: translateY(-5px);
                }

            .form-control {
                border-radius: 10px;
            }

            .btn {
                border-radius: 10px;
            }

            .card-header {
                border-radius: 15px 15px 0 0 !important;
            }
   </style>
</head>
<body>
@if (TempData["error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
        <strong>Error:</strong> @TempData["error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container mt-5">

    <!-- Header -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">
            Student Management System
        </h1>
        <p class="lead text-muted">
            Search and manage student records efficiently.
        </p>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-5">
        <div class="col-md-4 mb-3">
            <div class="card shadow border-0">
                <div class="card-body text-center">
                    <h5 class="text-primary">Students</h5>
                    <h2>250+</h2>
                    <p class="text-muted">Registered Students</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow border-0">
                <div class="card-body text-center">
                    <h5 class="text-success">Courses</h5>
                    <h2>50+</h2>
                    <p class="text-muted">Available Courses</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow border-0">
                <div class="card-body text-center">
                    <h5 class="text-danger">Faculty</h5>
                    <h2>30+</h2>
                    <p class="text-muted">Teaching Staff</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Search Form -->
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Search Student Record</h4>
        </div>

        <div class="card-body p-4">

            <form name="fr" action="/Home/Search" method="post">

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Enter Course ID
                    </label>

                    <input type="search"
                           name="Id"
                           class="form-control form-control-lg"
                           placeholder="Enter Course ID" />
                </div>

                <button type="submit" class="btn btn-primary btn-lg">
                    Search
                </button>

            </form>

        </div>
    </div>

    <!-- Features -->
    <div class="row mt-5">
        <div class="col-md-4 mb-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5>📚 Course Management</h5>
                    <p class="text-muted">
                        Manage course information and student enrollment.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5>👨‍🎓 Student Records</h5>
                    <p class="text-muted">
                        View and manage student academic records.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5>📊 Reports</h5>
                    <p class="text-muted">
                        Generate reports and monitor student performance.
                    </p>
                </div>
            </div>
        </div>
    </div>

</div>
</body>
</html>