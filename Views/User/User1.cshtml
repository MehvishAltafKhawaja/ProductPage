@model IEnumerable<WebApp.Models.User>


@{
    ViewData["Title"] = "Student Record";
}
@if (TempData["Message"] != null)
{
    <h1><b>Message: </b> @TempData["Message"]</h1>
}
<h1>User Record </h1>

<p>
    <a asp-action="Create" class="btn btn-success p-3"> Add New </a>
</p>

<table class="table">

    <thead>
        <tr>

            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ImageUrl)
            </th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>

                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Email)
                </td>
                <td>
                    <img src="/UserImages/@item.ImageUrl" width="100" height="100" />
                </td>

                <td>
                    <a class="btn btn-primary" asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a class="btn btn-warning" asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a class="btn btn-danger" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }

    </tbody>


</table>
