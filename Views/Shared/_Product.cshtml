@{
}

@model WebApp.Models.Product


<div class="card m-1" style="">
    <img src="@Model.imageName" asp-append-version ="true" class="card-img-top" alt="...">
    <div class="card-body">
        <h5 class="card-title">@Model.name</h5>
        <p class="card-text">@Model.discription</p>
        <p class="card-text">Rs. @Model.price</p>

        <a href="#" class="btn btn-primary">Buy</a>
        <a href="#" class="btn btn-warning">Add to Cart</a>
    </div>
</div>